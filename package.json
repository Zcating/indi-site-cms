{
  "name": "indi-site-cms",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "dev:web": "pnpm --filter web run dev",
    "dev:server": "pnpm --filter server run dev",
    "dev:main-site": "pnpm --filter main-site run dev",
    "build:main-site": "pnpm --filter main-site run build",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:mock": "node scripts/run-e2e.mjs",
    "test:e2e:real": "node scripts/run-e2e-real.mjs",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "db:generate": "pnpm --filter server run db:generate",
    "db:push": "pnpm --filter server run db:push",
    "db:studio": "pnpm --filter server run db:studio",
    "db:migrate": "pnpm --filter server run db:migrate"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  }
}
