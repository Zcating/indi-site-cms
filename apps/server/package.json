{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "npx dotenv -e .env -- npx prisma generate",
    "db:push": "npx dotenv -e .env -- npx prisma db push",
    "db:studio": "npx dotenv -e .env -- npx prisma studio",
    "db:migrate": "prisma migrate dev",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.0",
    "@fastify/multipart": "^8.1.0",
    "@fastify/static": "^7.0.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcrypt": "^5.1.1",
    "fastify": "^4.26.0",
    "fastify-plugin": "^4.5.1",
    "pg": "^8.20.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@prisma/config": "^7.4.2",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.11.0",
    "dotenv": "^17.3.1",
    "prisma": "^7.4.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
